{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "layer-shell": true,
  "cssPriority": "user",
  "control-center-margin-top": 5,
  "control-center-margin-bottom": 0,
  "control-center-margin-right": 0,
  "control-center-margin-left": 0,
  "notification-2fa-action": true,
  "notification-inline-replies": false,
  "notification-icon-size": 24,
  "notification-body-image-height": 100,
  "notification-body-image-width": 100,
  "notification-window-width": 300,
  "timeout": 6,
  "timeout-low": 3,
  "timeout-critical": 0,
  "fit-to-screen": false,
  "control-center-width": 450,
  "control-center-height": 726,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "script-fail-notify": true,
  "widgets": [
      "title",
      "buttons-grid",
      "dnd",
      "mpris",
      "volume",
      "backlight",
      "notifications"
  ],
  "widget-config": {
      "title": {
          "text": "Notifications",
          "clear-all-button": true,
          "button-text": "Clear"
      },
      "dnd": {
          "text": "Do Not Disturb"
      },
      "label": {
          "max-lines": 1,
          "text": "Notification"
      },
      "mpris": {
          "image-size": 36,
          "image-radius": 2
      },
      "volume": {
          "label": "󰕾"
      },
      "backlight": {
          "subsystem": "backlight",
          "device": "acpi_video0",
          "label": "󰃟"
      },
      "buttons-grid": {
          "buttons-per-row": 5,
          "actions": [
              {
                  "label": "󰐥",
                  "command": "pkill wlogout || wlogout --protocol layer-shell -b 3 -T 46 -B 46"
              },
              {
                  "label": "󰌾",
                  "command": "hyprlock"
              },
              {
                  "label": "󰍃",
                  "command": "niri msg action quit"
              },
              {
                  "label": "󰝟",
                  "command": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
              },
              {
                  "label": "󱩍",
                  "command": "pkill gammastep || gammastep-indicator"
              }
          ]
      }
  }
}
